# Google Service Account JSON (전체 JSON을 한 줄로)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Google Drive 폴더 ID (시트 파일이 생성될 폴더)
GDRIVE_FOLDER_ID=your_folder_id_here

# Google AI Studio에서 발급한 Gemini API 키
GEMINI_API_KEY=your_gemini_api_key_here
