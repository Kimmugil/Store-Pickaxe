# ── Google Sheets ────────────────────────────────────────────────
# 마스터 스프레드시트 ID (앱 목록 관리)
MASTER_SPREADSHEET_ID=

# Google 서비스 계정 JSON (한 줄로 minify)
GOOGLE_CREDENTIALS_JSON=

# Google Drive 폴더 ID (앱별 스프레드시트 생성 위치)
GDRIVE_FOLDER_ID=

# Google Apps Script 웹앱 URL (스프레드시트 생성용)
GAS_WEB_APP_URL=

# ── GitHub Actions ────────────────────────────────────────────────
# Personal Access Token (workflow 스코프 필요)
GITHUB_TOKEN=

# 레포지토리 (owner/repo 형식, 예: myname/store-pickaxe)
GITHUB_REPO=

# ── Gemini AI ─────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Admin ────────────────────────────────────────────────────────
# CONFIG 시트의 ADMIN_PASSWORD 키로 관리 (환경변수 불필요)
