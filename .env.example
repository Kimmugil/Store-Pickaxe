# ───────────────────────────────────────────────────────────────
# Store-Pickaxe 환경변수 예시
# 실제 사용 시 이 파일을 복사해 .env 로 저장하고 값을 채우세요.
# ───────────────────────────────────────────────────────────────

# Google 서비스 계정 자격증명 (JSON 전체를 한 줄로 붙여넣기)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"pickaxe@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# 마스터 스프레드시트 ID (URL에서 /d/XXXX/edit 부분의 XXXX)
MASTER_SPREADSHEET_ID=1BxiMVsEn...

# 앱별 스프레드시트가 생성될 Google Drive 폴더 ID
GDRIVE_FOLDER_ID=1Abc123...

# GAS 웹앱 URL (Apps Script 배포 후 발급되는 URL)
GAS_WEB_APP_URL=https://script.google.com/macros/s/AKfy.../exec

# Gemini API 키 (Google AI Studio에서 발급)
GEMINI_API_KEY=AIza...
